# Aul self-host configuration. Copy to `.env` and fill in. NEVER commit `.env`.
#
# Generate strong secrets with:
#   openssl rand -base64 48

# --- required ---

# Your exact external origin (scheme + host, no trailing path). Must be https in
# production. CORS and cookie scope derive from this.
PUBLIC_ORIGIN=https://aul.example.com

# Database password (used by both the db and server services).
POSTGRES_PASSWORD=change-me-strong-db-password

# Server-side secret mixed into session-token hashing. Rotating it invalidates
# all sessions. Keep it secret and stable.
SESSION_HASH_PEPPER=change-me-openssl-rand-base64-48

# --- optional (sensible defaults shown) ---

POSTGRES_USER=aul
POSTGRES_DB=aul
SERVER_PORT=8080

# Cookies require HTTPS when true (default). Set false ONLY for local http trials.
SECURE_COOKIES=true

# Honor X-Forwarded-For/X-Real-IP from your reverse proxy. Leave true behind
# Caddy/nginx; set false if the server is directly internet-facing.
TRUST_PROXY_HEADERS=true

# DANGER: lets the server read plaintext coordinates and do server-side
# geofencing. Disables E2EE. Keep false unless you fully trust this server.
TRUSTED_SERVER_MODE=false

# IP addresses in logs are kept at most this many days (0 disables IP logging).
IP_LOG_RETENTION_DAYS=7

# How long a sealed position ping is stored, in hours (1..168, default 6).
# The newest ping per device in a circle is ALWAYS kept, however old it is — a
# phone that has been off for days must still show its last known pin. Every
# older ping is dropped once past this window. Nothing reads ping history (the
# server only serves each device's latest position), so a longer window buys no
# feature and only widens what a stolen database reveals about when and how
# often people moved. Raise it only if you have a reason to.
PING_RETENTION_HOURS=6

# Per-circle retention_days: the default for a new circle and the maximum an
# owner may set. Governs place tombstones and resolved SOS events; for pings it
# is a floor only — a circle set below PING_RETENTION_HOURS drops its pings
# sooner (whichever rule deletes more, deletes). MAX_RETENTION_DAYS also bounds
# ping storage absolutely: whole monthly partitions past it are dropped.
DEFAULT_RETENTION_DAYS=7
MAX_RETENTION_DAYS=90

# Prometheus /metrics endpoint (keep off or firewall it if exposed).
METRICS_ENABLED=false

LOG_LEVEL=info

# --- TLS via Caddy (compose --profile tls) ---
AUL_DOMAIN=aul.example.com

# --- map tiles ---
# Origin the map loads tiles from; also allow-listed in the CSP. Default is
# OpenFreeMap (no API key, no tracking, privacy-respecting — see docs/DECISIONS
# D-0018). For ZERO third-party requests, self-host tiles (compose --profile
# tiles) and set this to your own origin, e.g. https://tiles.example.com. Set it
# empty for a blank basemap (markers only, no tile fetches at all).
TILES_ORIGIN=https://tiles.openfreemap.org
TILES_PORT=8082

# --- APK self-hosting ---
# Host directory (mounted at /apk) whose files are served at /download/<file>.apk
APK_DIR=/apk

# --- optional retention features (weekly digest, arrival alerts, reminders) ---
# Operator kill-switch. Default true; each user is still opted OUT until they
# turn a feature on themselves (see docs/DECISIONS D-0042). Set false to hide
# them for everyone on this deployment.
RETENTION_FEATURES_ENABLED=true

# --- Push, channel 1 of 2: Web Push (VAPID) — browsers ---
# Enables background "X arrived home" notifications for the web dashboard, even
# with the tab closed. Leave EMPTY to disable push (the server boots fine).
# Generate a keypair:  docker compose run --rm server aul vapid-keys
# The payload is sealed under the circle key before it reaches the server — the
# push service and the server only ever relay ciphertext.
# Rotating the keypair invalidates every existing subscription.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# RFC 8292 contact (mailto: or https:). Required when PUBLIC_ORIGIN isn't https.
VAPID_SUBJECT=mailto:ops@aul.example.com

# --- Push, channel 2 of 2: FCM (Firebase Cloud Messaging) — Android ---
# The Android app cannot receive Web Push while backgrounded, so notifications
# to phones go through FCM instead. Leave EMPTY to disable it: the server boots
# fine and Web Push is unaffected. The channels are fully independent — either
# alone, both, or neither.
#
# Setup:
#   1. Firebase console → Project settings → Service accounts → Generate new
#      private key. You get a JSON file.
#   2. Put it at deploy/fcm/service-account.json (docker-compose mounts
#      deploy/fcm read-only at /fcm).
#   3. Set the path INSIDE the container, below.
# The project id is read out of the JSON — do not configure it twice.
#
# THIS FILE IS A PRIVATE KEY: anyone holding it can send push as you. It is
# gitignored (service-account*.json), it is mounted read-only, and it is passed
# as a PATH rather than an env var so it never lands in `docker inspect`. Do not
# paste its contents here.
#
# E2EE: messages are DATA-ONLY (never an FCM `notification`), carrying the same
# blob the client sealed under the circle key. Android hands it to the app, which
# decrypts it locally. Google routes the ciphertext and cannot read it — a
# `notification` message would be rendered by the OS and would force plaintext.
FCM_SERVICE_ACCOUNT_FILE=
# e.g. FCM_SERVICE_ACCOUNT_FILE=/fcm/service-account.json
