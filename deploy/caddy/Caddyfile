# Caddy reverse proxy for Aul with automatic HTTPS (Let's Encrypt).
# The domain comes from the AUL_DOMAIN env var (set in deploy/.env).
#
# Edge rate-limiting complements (does not replace) the app's own per-account
# limits. Caddy's built-in rate limiting requires a plugin; the example relies on
# the application limits and connection limits below.

{$AUL_DOMAIN} {
	encode zstd gzip

	# Aul serves the API, WebSocket, web app, and APK downloads on one port.
	reverse_proxy server:8080 {
		# Preserve client IP for the app's per-IP rate limiting / audit.
		header_up X-Real-IP {remote_host}
		# Long timeouts for the realtime WebSocket.
		transport http {
			read_timeout 300s
			write_timeout 300s
		}
	}

	# Defense-in-depth headers (the app also sets these; Caddy reinforces).
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}

	log {
		output stdout
		format console
	}
}
