# Built web dashboard embedded into the server (generated by `make web`).
/server/cmd/aul/webdist/assets/
/server/cmd/aul/webdist/sw.js
/server/cmd/aul/webdist/workbox-*.js
/server/cmd/aul/webdist/registerSW.js
/server/cmd/aul/webdist/manifest.webmanifest
/server/cmd/aul/webdist/*.svg

# Firebase service-account keys — these ARE secret (they can send push as you).
# Keep them outside the repo entirely; the server reads a path from the env.
*firebase-adminsdk*.json
service-account*.json

# Database backups (contain the ciphertext DB — keep out of git)
deploy/backups/
